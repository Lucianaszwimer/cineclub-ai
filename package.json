{
  "name": "cineclub-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:nest": "tsx watch src/backend/main.ts",
    "test": "tsx --test src/backend/test/*.test.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:nest\"",
    "lint": "eslint",
    "build:front": "vite build",
    "build:back": "tsc -p tsconfig.backend.json",
    "build": "npm run build:front && npm run build:back",
    "start": "node dist/backend/main.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.8",
    "axios": "^1.16.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.2",
    "openai": "^6.39.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vite": "^8.0.14"
  }
}
